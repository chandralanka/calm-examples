{
    "$schema": "https://calm.finos.org/release/1.2/meta/calm.json",
    "$id": "https://example.com/patterns/company-base-pattern.json",
    "title": "Company Base Pattern",
    "description": "Base pattern that enforces company standards on all architectures, requiring all nodes to conform to the company node standard and all relationships to conform to the company relationship standard",
    "type": "object",
    "properties": {
        "nodes": {
            "type": "array",
            "items": {
                "$ref": "https://example.com/standards/company-node-standard.json"
            }
        },
        "relationships": {
            "type": "array",
            "items": {
                "$ref": "https://example.com/standards/company-relationship-standard.json"
            }
        }
    }
}